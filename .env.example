DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gto_wizard
REDIS_URL=redis://localhost:6379/0
NEON_DATABASE_URL=your_neon_connection_string_here

# API Server
API_PORT=8000
API_HOST=0.0.0.0

# Web App
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GRPC_URL=grpc://localhost:50051
NODE_ENV=development

# Solver Service  
SOLVER_PORT=50051
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# PostgreSQL (Neon cloud)
NEON_HOST=your_neon_host
NEON_PORT=5432
NEON_USER=your_neon_user
NEON_PASSWORD=your_neon_password
NEON_DATABASE=gto_wizard

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Environment
LOG_LEVEL=INFO