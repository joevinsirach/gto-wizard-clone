# =============================================================================
# Développement local (sans Docker)
# =============================================================================
PGUSER=postgres
PGPASSWORD=VOTRE_MOT_DE_PASSE
PGHOST=localhost
PGPORT=5432
PGDATABASE=gto_wizard

DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/gto_wizard

# Redis optionnel — laisser vide pour fakeredis (cache en mémoire, suffisant en dev)
REDIS_URL=

# API
API_PORT=8000
API_HOST=0.0.0.0

# Frontend Next.js (proxy /api → API_PORT)
# Frontend Next.js — laisser vide pour utiliser le proxy Next (/api/v1 → :8000)
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GRPC_URL=grpc://localhost:50051
NODE_ENV=development
WEB_PORT=3000

# Solver gRPC (optionnel — seulement si vous lancez apps/solver)
SOLVER_PORT=50051

LOG_LEVEL=INFO
